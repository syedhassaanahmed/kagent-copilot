# Local environment / secrets (never commit real values; commit .env.example instead)
.env
.env.local
*.env
!.env.example

# Secrets / credentials
*.key
*.pem
*-secret.yaml
secrets/

# Tool / build caches and logs
.tmp/
tmp/
.run/
*.log
*.tgz

# Python bytecode caches (scripts/copilot_teardown.py)
__pycache__/
*.pyc

# Runtime PID files (e.g. .ollama.pid written by scripts/20-ollama-up.sh)
*.pid

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
