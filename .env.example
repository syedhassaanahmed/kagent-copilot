# ===========================================================================
# kagent-n8n A2A demo — shared configuration
# Copy to .env (the scripts do this automatically) and adjust as needed.
# .env is git-ignored; .env.example is committed.
# ===========================================================================

# --- LLM backend (pluggable) ----------------------------------------------
# Provider selects how kagent's ModelConfig is rendered.
#   ollama       -> local model on the host (default; needs host plumbing)
#   openai       -> any OpenAI-compatible endpoint (set LLM_ENDPOINT + LLM_API_KEY)
#   azureOpenAI  -> Azure / MS AI Foundry (set LLM_ENDPOINT + LLM_API_KEY)
LLM_PROVIDER=ollama

# Model or deployment name (e.g. llama3.2:1b, qwen2.5:1.5b, gpt-4o-mini).
# Default qwen2.5:1.5b: tiny (~1GB) yet reliably returns prose over A2A.
# llama3.2:1b is smaller (~1.3GB, 1B) but a tiny model often emits spurious
# function-call JSON instead of an answer — switch only if you need the
# absolute smallest footprint.
LLM_MODEL=qwen2.5:1.5b

# Base URL / host for the LLM.
#   ollama:      leave BLANK to auto-derive a pod-reachable host endpoint,
#                or set explicitly e.g. http://172.18.0.1:11434
#   openai:      OpenAI-compatible base URL, e.g. https://api.openai.com/v1
#   azureOpenAI: the Azure endpoint, e.g. https://<resource>.openai.azure.com
LLM_ENDPOINT=

# API key for hosted providers. Leave BLANK for ollama.
LLM_API_KEY=

# Port Ollama listens on. On Docker Desktop + WSL2, IPv4-only Kind pods cannot
# reach a stock dual-stack Ollama through WSL2's default NAT-mode mirror; `make up`
# binds Ollama to IPv4 (OLLAMA_HOST=127.0.0.1:11434 via a systemd drop-in) so the
# default port stays 11434 and pods can reach it. See docs/troubleshooting.md.
OLLAMA_PORT=11434

# --- Kubernetes / kagent ---------------------------------------------------
KIND_CLUSTER_NAME=kagent-n8n
KAGENT_NAMESPACE=kagent

# Host-published NodePort that maps to the kagent controller A2A port (8083).
# Must be within the Kind/Kubernetes NodePort range (30000-32767).
KAGENT_A2A_NODEPORT=30883

# Agent CR name + namespace (the A2A server the n8n workflow talks to).
AGENT_NAME=a2a-demo-agent
AGENT_NAMESPACE=kagent

# --- n8n -------------------------------------------------------------------
N8N_PORT=5678

# Community A2A node installed into the n8n container.
N8N_A2A_NODE=@agentic-layer/n8n-nodes-a2a
